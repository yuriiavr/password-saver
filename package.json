{
  "name": "passwordsaver",
  "version": "1.4.5",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "electron-builder",
    "dist": "electron-builder",
    "start": "electron ."
  },
  "keywords": [],
  "author": "yuriiavr <yura.avramets@gmail.com>",
  "license": "ISC",
  "devDependencies": {
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8",
    "electron-reload": "^2.0.0-alpha.1"
  },
  "build": {
    "appId": "com.yuriiavr.passwordsaver",
    "publish": [
      {
        "provider": "github",
        "owner": "yuriiavr",
        "repo": "password-saver"
      }
    ],
    "productName": "Password Manager",
    "directories": {
      "output": "release"
    },
    "files": [
      "**/*",
      "!node_modules/.bin",
      "!node_modules/electron",
      "!node_modules/electron-builder",
      "!node_modules/electron-reload",
      "!release/"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "build/icon.png"
    }
  },
  "dependencies": {},
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yuriiavr/password-saver.git"
  },
  "bugs": {
    "url": "https://github.com/yuriiavr/password-saver/issues"
  },
  "homepage": "https://github.com/yuriiavr/password-saver#readme",
  "description": "A simple and secure password manager built with Electron."
}